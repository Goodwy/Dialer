<?xml version="1.0" encoding="utf-8"?>
<!--
    Ongoing-call notification content (DecoratedCustomViewStyle). The caller avatar is
    drawn on the left with the app icon badged in its bottom-right corner; the name is the
    title and the second line shows the live duration or the call status. Three round icon
    buttons (Speaker / Mute / Hang up) stay readable on every OEM skin because they are
    plain ImageViews with an explicit background, not system action chips.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notification_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/small_margin"
    android:gravity="center_vertical"
    tools:background="#222">

    <ImageView
        android:id="@+id/notification_thumbnail"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="@dimen/small_margin"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_person_vector"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginEnd="@dimen/tiny_margin"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notification_caller_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="?android:attr/textColorPrimary"
            android:textDirection="firstStrongLtr"
            tools:text="بدر هوساوي اروما"/>

        <TextView
            android:id="@+id/notification_call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="Ongoing call"/>

        <Chronometer
            android:id="@+id/notification_chronometer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:visibility="gone"
            tools:text="00:08"
            tools:visibility="visible"/>
    </LinearLayout>

    <!-- Ongoing call (Speaker / Mute / Hang up) -->
    <LinearLayout
        android:id="@+id/notification_actions_call_holder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:id="@+id/notification_speaker_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/small_margin"
            android:contentDescription="@string/audio_route_speaker"
            android:background="@drawable/bg_notification_btn_inactive"
            android:padding="8dp"
            android:src="@drawable/ic_volume_down_vector"
            android:tint="@android:color/white"/>

        <ImageView
            android:id="@+id/notification_mute_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/small_margin"
            android:contentDescription="@string/mute"
            android:background="@drawable/bg_notification_btn_inactive"
            android:padding="8dp"
            android:src="@drawable/ic_microphone_vector"
            android:tint="@android:color/white"/>

        <ImageView
            android:id="@+id/notification_decline_call_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/small_margin"
            android:contentDescription="@string/hang_up"
            android:background="@drawable/bg_notification_btn_hangup"
            android:padding="8dp"
            android:src="@drawable/ic_phone_down_vector"
            android:tint="@android:color/white"/>
    </LinearLayout>

    <!-- Incoming call (Decline / Accept) -->
    <LinearLayout
        android:id="@+id/notification_actions_holder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:id="@+id/notification_decline_call"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/small_margin"
            android:contentDescription="@string/decline"
            android:background="@drawable/bg_notification_btn_hangup"
            android:padding="8dp"
            android:src="@drawable/ic_phone_down_vector"
            android:tint="@android:color/white"/>

        <ImageView
            android:id="@+id/notification_accept_call"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/small_margin"
            android:contentDescription="@string/accept"
            android:background="@drawable/bg_notification_btn_accept"
            android:padding="8dp"
            android:src="@drawable/ic_phone_vector"
            android:tint="@android:color/white"/>
    </LinearLayout>
</LinearLayout>
