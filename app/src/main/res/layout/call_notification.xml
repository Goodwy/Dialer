<?xml version="1.0" encoding="utf-8"?>
<!--
    EXPANDED ("big") content view for the ongoing-call notification (setCustomBigContentView).
    The COLLAPSED view is the standard system-rendered notification (avatar = large icon with
    app badge, name = title, status/duration = text), so it stays readable in any theme with a
    single icon. This expanded view repeats the caller line and adds the three round monochrome
    action buttons (Speaker / Mute / Hang up) at the bottom. Text colours are set at runtime
    from the system dark/light mode because a RemoteView does not inherit the shade theme.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notification_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/tiny_margin"
    android:paddingBottom="@dimen/small_margin"
    tools:background="#222">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/notification_thumbnail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="@dimen/normal_margin"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_person_vector"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notification_caller_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:textDirection="firstStrongLtr"
                tools:text="بدر هوساوي اروما"/>

            <TextView
                android:id="@+id/notification_call_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textSize="13sp"
                android:textColor="#B3FFFFFF"
                tools:text="Ongoing call"/>

            <Chronometer
                android:id="@+id/notification_chronometer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#B3FFFFFF"
                android:visibility="gone"
                tools:text="00:08"
                tools:visibility="visible"/>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/normal_margin">

        <!-- Ongoing call: Speaker / Mute / Hang up -->
        <LinearLayout
            android:id="@+id/notification_actions_call_holder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/notification_speaker_button"
                android:layout_width="@dimen/notification_call_button_size"
                android:layout_height="@dimen/notification_call_button_size"
                android:contentDescription="@string/audio_route_speaker"
                android:background="@drawable/bg_notification_btn_subtle"
                android:padding="11dp"
                android:src="@drawable/ic_volume_down_vector"
                android:tint="@color/notification_button_icon"/>

            <ImageView
                android:id="@+id/notification_mute_button"
                android:layout_width="@dimen/notification_call_button_size"
                android:layout_height="@dimen/notification_call_button_size"
                android:layout_marginStart="@dimen/normal_margin"
                android:contentDescription="@string/mute"
                android:background="@drawable/bg_notification_btn_subtle"
                android:padding="11dp"
                android:src="@drawable/ic_microphone_vector"
                android:tint="@color/notification_button_icon"/>

            <ImageView
                android:id="@+id/notification_decline_call_button"
                android:layout_width="@dimen/notification_call_button_size"
                android:layout_height="@dimen/notification_call_button_size"
                android:layout_marginStart="@dimen/normal_margin"
                android:contentDescription="@string/hang_up"
                android:background="@drawable/bg_notification_btn_hangup"
                android:padding="11dp"
                android:src="@drawable/ic_phone_down_vector"
                android:tint="@android:color/white"/>
        </LinearLayout>

        <!-- Incoming call (pre-Android-12 fallback): Decline / Accept -->
        <LinearLayout
            android:id="@+id/notification_actions_holder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/notification_decline_call"
                android:layout_width="@dimen/notification_call_button_size"
                android:layout_height="@dimen/notification_call_button_size"
                android:contentDescription="@string/decline"
                android:background="@drawable/bg_notification_btn_hangup"
                android:padding="11dp"
                android:src="@drawable/ic_phone_down_vector"
                android:tint="@android:color/white"/>

            <ImageView
                android:id="@+id/notification_accept_call"
                android:layout_width="@dimen/notification_call_button_size"
                android:layout_height="@dimen/notification_call_button_size"
                android:layout_marginStart="@dimen/normal_margin"
                android:contentDescription="@string/accept"
                android:background="@drawable/bg_notification_btn_accept"
                android:padding="11dp"
                android:src="@drawable/ic_phone_vector"
                android:tint="@android:color/white"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
