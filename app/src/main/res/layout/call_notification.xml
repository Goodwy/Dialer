<?xml version="1.0" encoding="utf-8"?>
<!--
    Caller name, status text and avatar are pushed to the system notification
    header via setContentTitle / setContentText / setLargeIcon on the builder.
    This RemoteView only contains the action buttons so the whole layout fits
    in the collapsed notification height (~64dp) and the user can hit Hang up
    or Speaker without expanding the notification first.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/notification_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    tools:background="#333">

    <LinearLayout
        android:id="@+id/notification_actions_holder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/notification_decline_call"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/call_notification_button_size"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/small_margin"
            android:layout_marginEnd="@dimen/smaller_margin"
            android:contentDescription="@string/decline"
            android:background="@drawable/button_rounded"
            android:backgroundTint="@color/red_missed"
            android:padding="@dimen/small_margin"
            android:src="@drawable/ic_phone_down_vector"/>

        <ImageView
            android:id="@+id/notification_accept_call"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/call_notification_button_size"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/smaller_margin"
            android:layout_marginEnd="@dimen/small_margin"
            android:contentDescription="@string/accept"
            android:background="@drawable/button_rounded"
            android:backgroundTint="@color/green_call"
            android:padding="@dimen/small_margin"
            android:src="@drawable/ic_phone_vector"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/notification_actions_call_holder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/notification_decline_call_button"
            android:layout_width="0dp"
            android:layout_height="@dimen/call_notification_button_size"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/smaller_margin"
            android:layout_marginEnd="@dimen/tiny_margin"
            android:background="@drawable/button_rounded"
            android:backgroundTint="@color/red_missed"
            android:contentDescription="@string/hang_up"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/tiny_margin">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_phone_down_vector"
                android:tint="@android:color/white"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="@string/hang_up"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/notification_speaker_button"
            android:layout_width="0dp"
            android:layout_height="@dimen/call_notification_button_size"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/tiny_margin"
            android:background="@drawable/button_rounded"
            android:backgroundTint="@color/primary"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/tiny_margin">

            <ImageView
                android:id="@+id/notification_speaker_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_volume_down_vector"
                android:tint="@android:color/white"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="@string/audio_route_speaker"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/notification_mute_button"
            android:layout_width="0dp"
            android:layout_height="@dimen/call_notification_button_size"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/smaller_margin"
            android:background="@drawable/button_rounded"
            android:backgroundTint="@color/call_button_mute"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/tiny_margin">

            <ImageView
                android:id="@+id/notification_mute_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_microphone_vector"
                android:tint="@android:color/white"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="@string/mute"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
