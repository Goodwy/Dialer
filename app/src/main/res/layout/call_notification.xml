<?xml version="1.0" encoding="utf-8"?>
<!--
    Single-row notification layout modelled after the Samsung stock dialer
    notification: avatar on the left, caller info column in the middle, and a
    cluster of small round icon buttons on the right. Stays compact enough to
    render fully in the collapsed shade so the user can tap Hang up / Speaker /
    Mute without expanding.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notification_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/small_margin"
    android:gravity="center_vertical"
    tools:background="#222">

    <ImageView
        android:id="@+id/notification_thumbnail"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_person_vector"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/small_margin"
        android:layout_marginEnd="@dimen/tiny_margin"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notification_caller_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:textDirection="firstStrongLtr"
            tools:text="+966 11 522 2222"/>

        <TextView
            android:id="@+id/notification_call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:alpha="0.8"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            tools:text="Ongoing call"/>

        <Chronometer
            android:id="@+id/notification_chronometer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.8"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:visibility="gone"
            tools:text="00:08"
            tools:visibility="visible"/>
    </LinearLayout>

    <!-- Ongoing call (Speaker / Mute / Hang up) -->
    <LinearLayout
        android:id="@+id/notification_actions_call_holder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:id="@+id/notification_speaker_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="@dimen/tiny_margin"
            android:contentDescription="@string/audio_route_speaker"
            android:background="@drawable/button_rounded"
            android:backgroundTint="@color/primary"
            android:padding="6dp"
            android:src="@drawable/ic_volume_down_vector"
            android:tint="@android:color/white"/>

        <ImageView
            android:id="@+id/notification_mute_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="@dimen/tiny_margin"
            android:contentDescription="@string/mute"
            android:background="@drawable/button_rounded"
            android:backgroundTint="@color/call_button_mute"
            android:padding="6dp"
            android:src="@drawable/ic_microphone_vector"
            android:tint="@android:color/white"/>

        <ImageView
            android:id="@+id/notification_decline_call_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="@dimen/tiny_margin"
            android:contentDescription="@string/hang_up"
            android:background="@drawable/button_rounded"
            android:backgroundTint="@color/red_missed"
            android:padding="6dp"
            android:src="@drawable/ic_phone_down_vector"
            android:tint="@android:color/white"/>
    </LinearLayout>

    <!-- Incoming call (Decline / Accept) -->
    <LinearLayout
        android:id="@+id/notification_actions_holder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:id="@+id/notification_decline_call"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="@dimen/tiny_margin"
            android:contentDescription="@string/decline"
            android:background="@drawable/button_rounded"
            android:backgroundTint="@color/red_missed"
            android:padding="6dp"
            android:src="@drawable/ic_phone_down_vector"
            android:tint="@android:color/white"/>

        <ImageView
            android:id="@+id/notification_accept_call"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="@dimen/tiny_margin"
            android:contentDescription="@string/accept"
            android:background="@drawable/button_rounded"
            android:backgroundTint="@color/green_call"
            android:padding="6dp"
            android:src="@drawable/ic_phone_vector"
            android:tint="@android:color/white"/>
    </LinearLayout>
</LinearLayout>
